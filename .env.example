# TrueFoundry AI Gateway
TRUEFOUNDRY_BASE_URL=https://llm-gateway.truefoundry.com/api/inference/openai
TRUEFOUNDRY_API_KEY=your-truefoundry-api-key
TRUEFOUNDRY_MODEL=openai-main/gpt-4o-mini

# Auth0 (create a SPA application at https://manage.auth0.com)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Bland.ai Voice Escalation
BLAND_API_KEY=your-bland-api-key
BLAND_PATHWAY_ID=your-pathway-id
WEBHOOK_BASE_URL=https://your-tunnel.ngrok.io

# Server
PORT=3001

VITE_AIRBYTE_TOKEN=your_bearer_token
VITE_AIRBYTE_BASE_URL=https://api.airbyte.com/v1  # optional, this is the default
